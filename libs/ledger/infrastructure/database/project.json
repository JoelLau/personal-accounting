{
  "name": "libs/ledger/infrastructure/database",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/ledger/infrastructure/database",
  "tags": [],
  "targets": {
    "test": {
      "executor": "@nx-go/nx-go:test"
    },
    "lint": {
      "executor": "nx:noop",
      "dependsOn": [
        "lint:go",
        "lint:sql"
      ]
    },
    "lint:go": {
      "executor": "@nx-go/nx-go:lint"
    },
    "lint:sql": {
      "executor": "nx:noop"
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    },
    "generate": {
      "executor": "nx:noop",
      "dependsOn": [
        "sqlc:generate"
      ]
    },
    "sqlc:clean": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "migrate"
      ],
      "options": {
        "command": "rm -rf gen/*",
        "cwd": "{projectRoot}"
      },
      "outputs": [
        "{projectRoot}/dbgen/"
      ]
    },
    "sqlc:generate": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "sqlc:clean",
        "migrate"
      ],
      "options": {
        "command": "sqlc generate",
        "cwd": "{projectRoot}",
        "envFile": "{workspaceRoot}/.env"
      },
      "outputs": [
        "{projectRoot}/dbgen/"
      ]
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "goose -dir ./migrations/ postgres \"$DB_URL\" up",
        "cwd": "{projectRoot}",
        "envFile": "{workspaceRoot}/.env"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "migrate"
      ],
      "options": {
        "command": "goose -dir ./seed/ -no-versioning postgres \"$DB_URL\" up",
        "cwd": "{projectRoot}",
        "envFile": "{workspaceRoot}/.env"
      }
    }
  }
}