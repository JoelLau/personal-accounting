{
  "name": "packages/accounting",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/accounting",
  "tags": [],
  "targets": {
    "test": {
      "executor": "@nx-go/nx-go:test"
    },
    "lint": {
      "executor": "@nx-go/nx-go:lint"
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    },
    "generate": {
      "executor": "nx:noop",
      "dependsOn": ["sqlc:generate"]
    },
    "sqlc:generate": {
      "executor": "nx:run-commands",
      "dependsOn": ["migrate"],
      "options": {
        "command": "sqlc generate",
        "cwd": "{projectRoot}",
        "envFile": "{workspaceRoot}/.env"
      },
      "outputs": ["{projectRoot}/dbgen/"]
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "goose -dir ./migrations/ postgres \"$DB_URL\" up",
        "cwd": "{projectRoot}",
        "envFile": "{workspaceRoot}/.env"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "dependsOn": ["migrate"],
      "options": {
        "command": "goose -dir ./seed/ -no-versioning postgres \"$DB_URL\" up",
        "cwd": "{projectRoot}",
        "envFile": "{workspaceRoot}/.env",
      }
    }
  }
}
