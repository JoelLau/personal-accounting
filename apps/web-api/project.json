{
  "name": "apps/web-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "apps/web-api",
  "tags": [],
  "implicitDependencies": ["packages/integrations/api-spec"],
  "targets": {
    "serve": {
      "executor": "@nx-go/nx-go:serve",
      "options": {
        "main": "{projectRoot}/main.go"
      }
    },
    "test": {
      "executor": "@nx-go/nx-go:test"
    },
    "lint": { "executor": "@nx-go/nx-go:lint"
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    },
    "generate": {
      "executor": "nx:noop",
      "dependsOn": ["generate:api-spec"],
    },
    "generate:api-spec": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go tool oapi-codegen -config ./oapi_codegen.yaml ../../packages/integrations/api-spec/openapi.yaml",
        "cwd": "{projectRoot}"
      }
    }
  }
}
